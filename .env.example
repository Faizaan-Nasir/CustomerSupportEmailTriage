# Root environment variable template
# Copy the relevant values into:
# - apps/backend/.env
# - apps/frontend/.env

# --------------------------------------------------------------------
# Backend: Supabase Configuration
# --------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# --------------------------------------------------------------------
# Backend: Gemini API Configuration
# --------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key

# --------------------------------------------------------------------
# Backend: RAG and File Processing
# --------------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSION=1536

# --------------------------------------------------------------------
# Backend: Application Configuration
# --------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=info
INTERACTION_LIMIT=2
CONFIDENCE_THRESHOLD=0.75

# --------------------------------------------------------------------
# Backend: Worker / Async Configuration
# Optional but recommended when using Celery or async queues.
# --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --------------------------------------------------------------------
# Frontend Environment Variables
# --------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
