# Root environment variable template
# Copy the relevant values into:
# - apps/backend/.env
# - apps/frontend/.env
# - supabase/.env (optional, for local CLI usage)

# --------------------------------------------------------------------
# Backend: Supabase Configuration
# --------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# --------------------------------------------------------------------
# Backend: Gemini API Configuration
# --------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key

# --------------------------------------------------------------------
# Backend: Email Configuration
# Choose Gmail API and/or SMTP based on your integration approach.
# --------------------------------------------------------------------

# Gmail API
# GMAIL_CLIENT_ID=your-gmail-client-id
# GMAIL_CLIENT_SECRET=your-gmail-client-secret
# GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
# GMAIL_SENDER_EMAIL=support@example.com

# SMTP
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_SMTP_USER=your-email@gmail.com
GMAIL_SMTP_PASSWORD=your-smtp-password 

# --------------------------------------------------------------------
# Backend: RAG and File Processing
# --------------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSION=1536

# --------------------------------------------------------------------
# Backend: Application Configuration
# --------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=info
INTERACTION_LIMIT=2
CONFIDENCE_THRESHOLD=0.75

# --------------------------------------------------------------------
# Backend: Worker / Async Configuration
# Optional but recommended when using Celery or async queues.
# --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --------------------------------------------------------------------
# Frontend Environment Variables
# --------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
